generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ───────── existing metrics ─────────
model WebsiteMetric {
  id              String   @id @default(cuid())
  totalMouseMiles Float    @default(0)
  totalVisits     Int      @default(0)
  totalClicks     Int      @default(0)
  totalScroll     Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// ───────── new shared doodle board ─────────
///    • strokes is stored as raw JSON (array of strokes)
///    • each “upload” creates a new row; the client simply fetches the newest
model Drawing {
  id        String   @id @default(cuid())
  strokes   Json
  createdAt DateTime @default(now())
}

/// ───────── Taiwan trip planner ─────────

model TaipeiSettings {
  id   String @id @default("singleton")
  mode String @default("real")
}

model TaipeiDay {
  id        String        @id @default(cuid())
  dayNum    Int           @unique
  date      String
  label     String
  focus     String
  fakeFocus String        @default("")
  notes     String
  order     Int
  events    TaipeiEvent[]
}

model TaipeiEvent {
  id          String            @id @default(cuid())
  dayId       String
  time        String
  emoji       String
  title       String
  description String
  location    String
  transit     String
  tips        String
  order       Int
  realOnly    Boolean           @default(false)
  fakeOnly    Boolean           @default(false)
  day         TaipeiDay         @relation(fields: [dayId], references: [id], onDelete: Cascade)
  checklist   TaipeiCheckItem[]
}

model TaipeiCheckItem {
  id      String      @id @default(cuid())
  eventId String
  label   String
  done    Boolean     @default(false)
  order   Int
  event   TaipeiEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
}
